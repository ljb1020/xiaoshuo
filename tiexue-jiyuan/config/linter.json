{
  "censorship_rules": {
    "(?<!龙)中国(?!.*龙国)": "龙国",
    "(?<![樱花])日本": "樱花国",
    "(?<![鹰])美国": "鹰酱",
    "(?<![鹰酱])美军": "鹰酱军",
    "苏联": "毛熊",
    "俄罗斯": "毛熊",
    "(?<![约翰牛])英国": "约翰牛",
    "(?<![高卢鸡])法国": "高卢鸡",
    "(?<![汉斯猫])德国": "汉斯猫",
    "055(?:大驱|级|舰|驱逐舰)": "0VV大驱",
    "(?:歼20|歼-20|J-?20)": "J-VV隐身战机",
    "075(?:两栖舰|级|舰)": "0QV两栖舰",
    "99A(?:主战坦克|坦克|式)": "9VA坦克"
  },
  "ai_warning_patterns": {
    "总而言之": "机械过渡词，建议改写",
    "综上所述": "机械过渡词，建议改写",
    "不仅如此": "机械过渡词，建议改写",
    "然而不可思议的是": "典型AI句式，建议简化",
    "倒吸一?口凉气": "机械反应词，建议用具体动作替代",
    "嘴角勾起一抹(?:冷笑|弧度)": "机械表情词，建议用具体动作替代",
    "深邃的眼眸": "机械外貌词，建议用具体描写替代",
    "宛如一幅画卷": "过度修辞，建议删除或改写"
  },
  "ignore": {
    "skip_frontmatter": true,
    "skip_code_fence": true,
    "skip_blockquote": true,
    "skip_tables": false
  }
}
